rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'ADMIN' || getUserData().role == 'GESTOR' || request.auth.token.email == 'samuel.bagolin@setuptecnologia.com.br');
    }

    function isClientOf(customerId) {
      return isAuthenticated() && getUserData().role == 'CLIENTE' && getUserData().customerId == customerId;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /customers/{customerId} {
      allow read: if isAdmin() || isClientOf(customerId);
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create: if isAdmin() || (isAuthenticated() && request.auth.token.email == 'samuel.bagolin@setuptecnologia.com.br');
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || isClientOf(resource.data.customerId);
      allow write: if isAdmin();
      allow update: if isAdmin() || (isClientOf(resource.data.customerId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
    }

    match /meetings/{meetingId} {
      allow read: if isAdmin() || isClientOf(resource.data.customerId);
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isAdmin() || isClientOf(resource.data.customerId);
      allow write: if isAdmin();
    }
  }
}
